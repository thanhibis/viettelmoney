<section class="sec-content">
	<div class="inner">
		<nav>
			<ol class="breadcrumb">
				<li class="breadcrumb-item"><a href="">Trang chủ</a></li>
				<li class="breadcrumb-item"><a href="">Tài chính</a></li>
				<li class="breadcrumb-item active">Giới thiệu về chúng tôi</li>
			</ol>
		</nav>
		<div class="client-block">
			<div class="client-block__img">
				<img src="<%= RELATIVE_PATH %>img/search.png" alt="img">
			</div>
			<h2 class="client-block__ttl">TRA CỨU Điểm xếp hạng khách hàng</h2>
			<div class="client-block__ct">
				<div class="client-block__ct-item">
					<input type="text" class="form-control" placeholder="Số điện thoại">
					<small>Số điện thoại</small>
				</div>
				<div class="client-block__ct-item">
					<input type="text" class="form-control" placeholder="Số giấy tờ tùy thân">
					<small>Số giấy tờ tùy thân</small>
				</div>
				<p>
					<i>Điểm xếp hạng khách hàng do khách hàng thực hiện tra cứu trên ứng dụng Viettel Money của Viettel</i>
				</p>
			</div>
			<div class="client-block__sub">
				<button type="button" class="c-btn__01">Tiếp tục</button>
			</div>
		</div>
	</div>
</section>
<section class="sec-support">
	<div class="inner">
		<h2 class="c-ttl__01">Nhận thông tin từ chúng tôi</h2>
		<div class="support-note c-al--c">
			<p>
				Đừng bỏ lỡ những chương trình khuyến mãi cùng quà tặng hấp dẫn đến từ chúng tôi
			</p>
		</div>
		<div class="support-block">
			<div class="support-block__item">
				<input type="text" class="form-control" placeholder="Họ tên *">
			</div>
			<div class="support-block__item">
				<input type="text" class="form-control" placeholder="Số điện thoại *">
			</div>
			<div class="support-block__item">
				<input type="text" class="form-control" placeholder="Email *">
			</div>
		</div>
	</div>
</section>

<div class="popup popup--small active" id="popup-error">
	<div class="popup-bg js-close"></div>
	<div class="popup-content">
		<div class="popup-content__close popup-content__close--02 js-close">
			<img src="<%= RELATIVE_PATH %>img/close02.png" alt="img">
		</div>
		<div class="popup-img">
			<img src="<%= RELATIVE_PATH %>img/error.png" alt="img">
		</div>
		<div class="popup-error c-al--c">
			<p>
				Thông tin không chính xác. <br class="sp">Vui lòng kiểm tra và nhập lại.
			</p>
			<button type="button" class="c-btn__01 js-close">Đóng</button>
		</div>
	</div>
</div>